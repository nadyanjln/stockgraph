# ===== PostgreSQL =====
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=chatbot_db

# Pool tuning
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Set to "true" to echo SQL statements to stdout (useful for dev)
DB_ECHO=false

# ===== FalkorDB / GraphRAG =====
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_CONNECT_TIMEOUT=0.5
FALKORDB_HEALTH_CHECK_INTERVAL=5
STOCKGRAPH_INGEST_TIMEOUT_SECONDS=180
STOCKGRAPH_FINALIZE_TIMEOUT_SECONDS=90

# ===== Hybrid Retrieval Tuning =====
DEBUG_RAG=false
TOP_K_VECTOR=8
TOP_K_GRAPH=12
TOP_K_FINAL=8
SIMILARITY_THRESHOLD=0.08
MAX_CONTEXT_LENGTH=6000
PER_CONTEXT_MAX_CHARS=1200
RERANK_ENABLED=true
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
GRAPH_DEPTH=2

# ===== App =====
LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:5173

# ===== RAGAS Evaluation =====
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
RAGAS_EVAL_DATASET=evaluation/sample_dataset.json
RAGAS_EVAL_TIMEOUT_SECONDS=120
RAGAS_EVAL_MAX_RETRIES=2

# ===== Supabase Auth =====
# Backend token validation
SUPABASE_URL=https://hmchxeqvsobrfzqhnvmx.supabase.co
SUPABASE_ANON_KEY=sb_publishable_djL8rAu4XEzWbVzEYyFYWw_fg8jCMzF
SUPABASE_AUTH_TIMEOUT_SECONDS=8

# Frontend (copy these values to frontend/.env)
VITE_API_BASE_URL=http://localhost:8000
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
