# ===== PostgreSQL =====
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=chatbot_db

# Pool tuning
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Set to "true" to echo SQL statements to stdout (useful for dev)
DB_ECHO=false

# ===== FalkorDB / GraphRAG =====
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_CONNECT_TIMEOUT=0.5
FALKORDB_HEALTH_CHECK_INTERVAL=5
STOCKGRAPH_INGEST_TIMEOUT_SECONDS=180
STOCKGRAPH_FINALIZE_TIMEOUT_SECONDS=90

# ===== App =====
LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:5173

# ===== Supabase Auth =====
# Backend token validation
SUPABASE_URL=https://hmchxeqvsobrfzqhnvmx.supabase.co
SUPABASE_ANON_KEY=sb_publishable_djL8rAu4XEzWbVzEYyFYWw_fg8jCMzF
SUPABASE_AUTH_TIMEOUT_SECONDS=8

# Frontend (copy these values to frontend/.env)
VITE_API_BASE_URL=http://localhost:8000
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
